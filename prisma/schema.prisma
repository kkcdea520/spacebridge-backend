// 这是SpaceBridge世越装饰官网的数据库schema
// 数据库：SQLite（轻量级，易于本地开发和部署）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户咨询表单
model Consultation {
  id          String   @id @default(uuid())  // 唯一ID
  name        String                        // 姓名
  phone       String                        // 电话
  email       String?                       // 邮箱（可选）
  company     String?                       // 公司名称（可选）
  serviceType String                        // 服务类型
  message     String                        // 咨询内容
  status      String   @default("pending")  // 状态：pending（待处理）/ processed（已处理）
  createdAt   DateTime @default(now())     // 创建时间
  updatedAt   DateTime @updatedAt           // 更新时间
}

// 新闻订阅
model Subscription {
  id        String   @id @default(uuid())
  email     String   @unique  // 邮箱，唯一
  status    String   @default("active")  // 状态：active（活跃）/ unsubscribed（已退订）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 反馈/建议
model Feedback {
  id        String   @id @default(uuid())
  name      String
  email     String?
  type      String   // 类型：feedback（反馈）/ suggestion（建议）/ complaint（投诉）
  subject   String   // 主题
  message   String   // 内容
  status    String   @default("pending")  // 状态
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
