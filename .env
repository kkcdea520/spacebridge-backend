# SpaceBridge世越装饰官网 - 后端环境变量配置

# 数据库连接（SQLite本地数据库）
DATABASE_URL="file:./dev.db"

# 服务器端口
PORT=3007

# 邮件配置（用于发送咨询通知邮件）
# 推荐使用QQ邮箱或163邮箱的SMTP服务
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=renhuaimin88@qq.com
SMTP_PASS=your-smtp-auth-code

# 邮件发送配置
EMAIL_FROM=SpaceBridge世越装饰 <renhuaimin88@qq.com>
EMAIL_TO=renhuaimin88@qq.com

# 前端地址（用于CORS配置）
FRONTEND_URL=http://localhost:3000

# 环境模式
NODE_ENV=development
